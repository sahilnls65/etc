{
  "manifest_version": 3,
  "name": "Emgage work hour calculator",
  "version": "1.0",
  "description": "Extract Net Hours from Emgage website and calculate finish time",

  "browser_specific_settings": {
    "gecko": {
      "id": "work-hours-extension@sahil",
      "strict_min_version": "140.0",
      "strict_min_version_android": "142.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },

  "permissions": ["activeTab", "scripting", "storage"],

  "action": {
    "default_popup": "popup.html",
    "default_title": "Emgage work hour calculator",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "content_scripts": [
    {
      "matches": ["https://*.emgage.work/*"],
      "js": ["content.js"]
    }
  ]
}
